# ==============================================
# UDAAN BACKEND - ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/udaan_dev
MONGODB_URI_TEST=mongodb://localhost:27017/udaan_test

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# JWT Cookie
JWT_COOKIE_EXPIRES_IN=7

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/v1/auth/linkedin/callback

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=noreply@udaan.community
EMAIL_FROM_NAME=Udaan Platform

# File Upload
MAX_FILE_UPLOAD=10485760
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Encryption
BCRYPT_ROUNDS=12

# Admin
ADMIN_EMAIL=admin@udaan.community
ADMIN_PASSWORD=change_this_password_immediately
